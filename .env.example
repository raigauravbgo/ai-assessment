# =============================================================================
# Required to run anything
# =============================================================================

# Postgres connection string. Options for dev:
#   - `npx prisma dev` runs Postgres locally and prints a URL
#   - Railway: New Postgres → copy the "Postgres Connection URL" value
#   - Neon / Supabase / Prisma Postgres free tier all work
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Cookie encryption secret for iron-session. Must be at least 32 chars.
# Generate one: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET="replace-with-a-32-plus-char-random-hex-string"

# Single admin password (PRD §9). The admin enters this on /admin/login.
ADMIN_PASSWORD="change-me"

# =============================================================================
# Scoring pipeline — provider-agnostic (OpenAI chat-completions wire format)
# =============================================================================

# Pick any provider that speaks the OpenAI wire format. Examples:
#
#   OpenRouter (default, routes to any model — Claude / GPT / Llama / etc.):
#     SCORING_BASE_URL="https://openrouter.ai/api/v1"
#     SCORING_API_KEY="sk-or-..."
#     SCORING_MODEL="anthropic/claude-sonnet-4.5"
#
#   OpenAI direct:
#     SCORING_BASE_URL="https://api.openai.com/v1"
#     SCORING_API_KEY="sk-..."
#     SCORING_MODEL="gpt-4o-2024-08-06"
#
#   Anthropic via their OpenAI-compat shim, Together, Groq, local LiteLLM — any
#   provider speaking OpenAI's chat-completions wire format works.
#
# Defaults are OpenRouter + Claude Sonnet 4.5 (PRD §9's Claude spec, no direct
# Anthropic key needed).
SCORING_BASE_URL="https://openrouter.ai/api/v1"
SCORING_API_KEY=""
SCORING_MODEL="anthropic/claude-sonnet-4.5"

# =============================================================================
# Zip uploads — local FS, with optional path override for production
# =============================================================================

# Where uploaded zips are written. Defaults to `./uploads`. On Railway, mount
# a Volume at `/data/uploads` and set this to `/data/uploads` so files survive
# container restarts.
# UPLOADS_DIR="/data/uploads"

# =============================================================================
# Production deployment
# =============================================================================

# Public base URL of the deployed app (used by scripts/create-participant.ts
# to print the right token link). Local dev defaults to http://localhost:3000.
# APP_BASE_URL="https://ai-evaluator.up.railway.app"
